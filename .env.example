# Policy Intelligence Pipeline - environment configuration
#
# The app runs end-to-end with NO keys set (deterministic offline engine).
# Paste ONE key below to upgrade the agents to a live LLM. Auto-detection picks
# whichever key is present, regardless of PIP_LLM_PROVIDER.

# Provider options: "offline" (default), "anthropic", "openai", "groq"
PIP_LLM_PROVIDER=offline

# --- Provider keys (only one is needed) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Models used when live
PIP_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
PIP_OPENAI_MODEL=gpt-4o
PIP_GROQ_MODEL=llama-3.3-70b-versatile

# Allow live network fetches of public CMS sources (true/false).
PIP_ALLOW_NETWORK_FETCH=false

# Auto-approve seed edits when running demo prepare --reset (true/false).
PIP_DEMO_AUTO_APPROVE=true
